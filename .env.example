# ──────────────────────────────────────────────
# Required (pick at least one AI provider)
# ──────────────────────────────────────────────

# Google Gemini (recommended — free tier, no credit card)
# https://aistudio.google.com/apikey
# GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here

# Premium Gemini key — used for signed-in users (regular + admin) instead of
# the free key above. Leave unset to use the same key for everyone.
# GOOGLE_GENERATIVE_AI_API_KEY_PREMIUM=your_premium_key_here

# Gemini model to use (default: gemini-3.1-flash-lite)
# GOOGLE_GENERATIVE_AI_MODEL=gemini-3.1-flash-lite

# ──────────────────────────────────────────────
# Optional Free-Tier Fallback Providers
# ──────────────────────────────────────────────

# Groq (fast open-source models, free tier)
# https://console.groq.com/keys
# GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter (access to many free models)
# https://openrouter.ai/settings/keys
# OPENROUTER_API_KEY=your_openrouter_key_here
# OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free

# ──────────────────────────────────────────────
# Optional: Vercel AI Gateway (advanced)
# ──────────────────────────────────────────────

# Enable only if you have a Vercel account with AI Gateway access
# USE_VERCEL_AI_GATEWAY=1
# AI_GATEWAY_API_KEY=
# AI_GATEWAY_MODEL=google/gemini-3.1-flash-lite

# ──────────────────────────────────────────────
# Database (required)
# ──────────────────────────────────────────────

# Neon Postgres (free tier: https://neon.tech)
# POSTGRES_URL=your_neon_database_url_here

# ──────────────────────────────────────────────
# Auth (required)
# ──────────────────────────────────────────────

# Generate: `openssl rand -base64 32` or https://generate-secret.vercel.app/32
# AUTH_SECRET=your_random_secret_here

# ──────────────────────────────────────────────
# Optional Storage & Cron
# ──────────────────────────────────────────────

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/redis
REDIS_URL=****

# Secret for guest cleanup cron (generate with `openssl rand -base64 32`)
CRON_SECRET=****

# ──────────────────────────────────────────────
# LLM Call Optimisation
# ──────────────────────────────────────────────

# By default, chat titles are deterministic (no LLM call).
# Set to 1 to use the LLM for generating chat titles.
# ENABLE_LLM_TITLE_GENERATION=0

# ──────────────────────────────────────────────
# Mode & Limits
# ──────────────────────────────────────────────

# APP_MODE=FREE (default) — guests see 5 questions/day, 24h retention, no history.
# APP_MODE=PREMIUM — gates future features (admin dashboards, approval workflows).
# Note: APP_MODE does NOT affect the AI provider. Use GOOGLE_GENERATIVE_AI_API_KEY
# vs GOOGLE_GENERATIVE_AI_API_KEY_PREMIUM to route different keys by user type.
APP_MODE=FREE

# How long guest chat history is kept before auto-cleanup (hours).
FREE_CHAT_RETENTION_HOURS=24

# Maximum questions a guest can answer per day.
GUEST_DAILY_QUESTION_LIMIT=5

# Optional: webhook URL (Slack/Discord/Zapier incoming webhook) notified when a
# student requests a topic that isn't in the curriculum yet. Leave unset to
# disable notifications (requests are still logged to the TopicRequest table).
# TOPIC_REQUEST_WEBHOOK_URL=https://hooks.slack.com/services/...
