# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# fallback model used when the AI Gateway is rate limited / unavailable
# https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****

# secret protecting the scheduled guest-cleanup cron (Vercel sends it as a
# Bearer token). Generate with `openssl rand -base64 32`. Optional in local dev.
CRON_SECRET=****
